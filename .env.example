# Helix-Signal — infrastructure / deployment only.
# Copy: cp .env.example .env
#
# User-facing config (AI keys, toggles, alerts) → Settings UI after admin login.
#
# DEPLOYMENT RULE — READ BEFORE REDEPLOY
# On the server: back up, DELETE the old .env, regenerate from this file,
# fill secrets fresh (never merge stale keys). See .progress/CURSOR.md.

# --- Core ---
HELIX_DOMAIN=helix.local
DATABASE_URL=postgresql+psycopg2://helix:CHANGE_ME@postgres:5432/helix
# Local venv SQLite alternative:
# DATABASE_URL=sqlite:///helix.db

HELIX_USE_ALEMBIC=true
REDIS_URL=redis://redis:6379/0
POSTGRES_USER=helix
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=helix
REFRESH_INTERVAL_SECONDS=300
TREND_RETENTION_DAYS=90
EVENT_RETENTION_DAYS=30
OSINT_RETENTION_DAYS=30
CHAIN_TREND_RETENTION_DAYS=90
ALLOW_BACKFILL=false
ONNX_DEPEG_MODEL_PATH=backend/ml_models/helix_fiat_depeg_v4_heuristic.onnx
ONNX_FUNDING_MODEL_PATH=backend/ml_models/helix_funding_regime_v4_heuristic.onnx
ONNX_YIELD_MODEL_PATH=backend/ml_models/helix_yield_sustainability_v4_heuristic.onnx
# V4 auto-resolves type-specific models from backend/ml_models/*.onnx (no env var needed)
MODEL_DIR=/data/models

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=dev

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost,http://localhost:3000

# --- AI (infrastructure default; tune in Settings UI) ---
AI_MODE=ai_off

# --- Security (REQUIRED) ---
# Generate with: openssl rand -hex 32
# REQUIRED before first deploy — leave blank and login will return 503.
SESSION_SIGNING_KEY=

# --- Admin (single-admin OSS bootstrap) ---
HELIX_ADMIN_TOKEN=
HELIX_ADMIN_USERNAME=admin
HELIX_ADMIN_PASSWORD=

# --- Optional V4 data source providers (set via Settings UI → API Keys; env fallback only) ---
# COINGLASS_API_KEY=
# ETHERSCAN_API_KEY=
# COINGLASS_BASE_URL=https://api.coinglass.com
# ETHERSCAN_BASE_URL=https://api.etherscan.io

# --- Optional on-chain providers (set via Settings UI → API Keys; env fallback only) ---
# CHAINLINK_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# MORALIS_API_KEY=
# FLIPSIDE_API_KEY=
# ALCHEMY_API_KEY=
# ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# THEGRAPH_API_KEY=

# --- Optional V4 blacklist / intel ---
# BLACKLIST_API_URL=
# BLACKLIST_API_KEY=
# INTEL_WEBHOOK_URL=
# INTEL_WEBHOOK_SECRET=

# --- Optional deploy / proxy ---
# HELIX_DEPLOY_REMOTE=user@host
# Set to your Docker/internal network CIDR so the rate limiter trusts X-Forwarded-For only from nginx.
TRUSTED_PROXY_CIDR=10.0.0.0/8
