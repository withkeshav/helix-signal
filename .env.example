# Copy to .env for local or Docker Compose: cp .env.example .env
#
# DATABASE_URL modes:
# - Local venv (from backend/): sqlite:///helix.db  -> backend/helix.db (default if unset)
# - Docker Compose: sqlite:///data/helix.db       -> /data/helix.db volume mount
# - Custom path: sqlite:////absolute/path/to/helix.db

# --- Core ---
HELIX_DOMAIN=helix.local
# Comma-separated CORS origins (default: *). Set for production:
# CORS_ORIGINS=https://app.helixsignal.com,https://admin.helixsignal.com
# CORS_ORIGINS=*
# Local dev (default):
DATABASE_URL=sqlite:///helix.db
# VPS / Timescale (docker compose --profile data):
# DATABASE_URL=postgresql+psycopg2://helix:helix@postgres:5432/helix
# HELIX_USE_ALEMBIC=true
# REDIS_URL=redis://redis:6379/0
# MLFLOW_TRACKING_URI=http://mlflow:5000
# SQLITE_SOURCE_URL=sqlite:///data/helix.db   # for scripts/migrate_sqlite_to_postgres.py
HELIX_USE_ALEMBIC=false
REDIS_URL=redis://localhost:6379/0
# Celery removed in v3.4.0 — forecasts run via APScheduler
ENABLE_REDIS_CACHE=false
REDIS_CACHE_TTL_SECONDS=45
ENABLE_MLFLOW=true
ENABLE_PREDICTIVE=true
ONNX_DEPEG_MODEL_PATH=backend/models/depeg.onnx
TIMESFM_ENDPOINT=http://timesfm:8100
REFRESH_INTERVAL_SECONDS=300
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix
POSTGRES_DB=helix
TREND_RETENTION_DAYS=90
EVENT_RETENTION_DAYS=30
FORECAST_RETENTION_DAYS=30
OSINT_RETENTION_DAYS=30
CHAIN_TREND_RETENTION_DAYS=90
CLICKHOUSE_HOST=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_PORT=8123
ALLOW_BACKFILL=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=dev

# --- Rate Limiting ---
# RATE_LIMITER_STORAGE_URI=redis://localhost:6379/1

# --- Source API Keys (optional) ---
CHAINLINK_RPC_URL=
CHAINLINK_POR_CONTRACT=
ENABLE_CHAINLINK=false
ENABLE_DYNAMIC_CHAINS=false

# --- AI (optional add-on; core APIs work with AI_MODE=ai_off) ---
AI_MODE=ai_off
ENABLE_ANOMALY_DETECTION=false
ENABLE_NLP=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OLLAMA_CLOUD_BASE_URL=
OLLAMA_CLOUD_MODEL=llama3.2:3b
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_DAILY_TOKEN_BUDGET=50000
MODEL_DIR=/data/models
MLFLOW_EXPERIMENT=helix-predictive

# --- Alerts (optional) ---
ALERT_WEBHOOK_URL=
ALERT_DISCORD_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# --- Deploy (optional) ---
# HELIX_DEPLOY_REMOTE=user@host
# HELIX_SMOKE_URL=http://localhost:8000

# --- Security ---
# Content-Security-Policy header (backend + nginx). Customize for production:
# CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' https://cdn.jsdelivr.net 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# --- Admin ---
HELIX_ADMIN_TOKEN=
