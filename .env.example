# Copy to .env for local or Docker Compose: cp .env.example .env
#
# All user-facing configuration (API keys, models, feature toggles, alert
# dispatch, refresh intervals, CORS) is managed from the Settings UI at /settings.
# This file contains only infrastructure/deployment vars.

# --- Core ---
HELIX_DOMAIN=helix.local

# DATABASE_URL modes:
# - Local venv (from backend/): sqlite:///helix.db  -> backend/helix.db (default if unset)
# - Docker Compose (default): postgresql://...@postgres:5432/helix (uses POSTGRES_* vars)
# - Override to SQLite: DATABASE_URL=sqlite:///data/helix.db
DATABASE_URL=sqlite:///helix.db
# For the companion Postgres (docker compose up), uncomment:
# DATABASE_URL=postgresql+psycopg2://helix:helix@postgres:5432/helix
# REDIS_URL=redis://redis:6379/0
# SQLITE_SOURCE_URL=sqlite:///data/helix.db   # for scripts/migrate_sqlite_to_postgres.py
HELIX_USE_ALEMBIC=false
REDIS_URL=redis://localhost:6379/0
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix
POSTGRES_DB=helix
MODEL_DIR=/data/models
ONNX_DEPEG_MODEL_PATH=backend/models/depeg.onnx

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=dev

# --- Rate Limiting ---
# RATE_LIMITER_STORAGE_URI=redis://localhost:6379/1
# TRUSTED_PROXY_CIDR=10.0.0.0/8

# --- Deploy (optional) ---
# HELIX_DEPLOY_REMOTE=user@host
# HELIX_SMOKE_URL=http://localhost:8000

# --- Security ---
# Content-Security-Policy header (backend + nginx). Customize for production:
# CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' https://cdn.jsdelivr.net 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# --- Admin ---
HELIX_ADMIN_TOKEN=

# --- Session Signing ---
# REQUIRED. HMAC-SHA256 key for signed session tokens.
# Generate: openssl rand -hex 32
SESSION_SIGNING_KEY=

# --- Feature Flags ---
# ENABLE_NLP=true
# ENABLE_ANOMALY_DETECTION=true
# (ENABLE_NLP_SENTIMENT is legacy alias; use ENABLE_NLP)
# Webhook alert settings (primary dispatch): webhook_enabled, webhook_url, webhook_signing_secret, webhook_min_severity, webhook_timeout_seconds
# All user-facing config including these is managed via the Settings UI at /settings (admin token required).
# ENABLE_REDIS_CACHE=true
# ENABLE_CHAINLINK=true

# --- Source API Keys (first-time bootstrap; manage via Settings UI after) ---
# See Settings UI at /settings to configure all providers, keys, models, and features.
OPENROUTER_API_KEY=
OLLAMA_API_KEY=
GROQ_API_KEY=

# --- Additional Configuration ---
# CORS origins (comma-separated)
# CORS_ORIGINS=*

# Alert SMTP settings
# ALERT_SMTP_HOST=smtp.gmail.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=your-email@gmail.com
# ALERT_SMTP_PASS=your-app-password

# Discord webhook
# ALERT_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
