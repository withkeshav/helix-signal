# Copy to .env for local or Docker Compose: cp .env.example .env
#
# DATABASE_URL modes:
# - Local venv (from backend/): sqlite:///helix.db  -> backend/helix.db (default if unset)
# - Docker Compose: sqlite:///data/helix.db       -> /data/helix.db volume mount
# - Custom path: sqlite:////absolute/path/to/helix.db

# --- Core ---
HELIX_DOMAIN=helix.local
# Comma-separated CORS origins (default: *). Set for production:
# CORS_ORIGINS=https://app.helixsignal.com,https://admin.helixsignal.com
# CORS_ORIGINS=*
# Local dev (default):
DATABASE_URL=sqlite:///helix.db
# VPS / Timescale (docker compose --profile data):
# DATABASE_URL=postgresql+psycopg2://helix:helix@postgres:5432/helix
# HELIX_USE_ALEMBIC=true
# REDIS_URL=redis://redis:6379/0
# SQLITE_SOURCE_URL=sqlite:///data/helix.db   # for scripts/migrate_sqlite_to_postgres.py
HELIX_USE_ALEMBIC=false
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_CACHE=false
REDIS_CACHE_TTL_SECONDS=45
ENABLE_PREDICTIVE=true
ONNX_DEPEG_MODEL_PATH=backend/models/depeg.onnx
REFRESH_INTERVAL_SECONDS=300
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix
POSTGRES_DB=helix
TREND_RETENTION_DAYS=90
EVENT_RETENTION_DAYS=30
OSINT_RETENTION_DAYS=30
CHAIN_TREND_RETENTION_DAYS=90
CLICKHOUSE_HOST=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_PORT=8123
ALLOW_BACKFILL=false

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=dev

# --- Rate Limiting ---
# RATE_LIMITER_STORAGE_URI=redis://localhost:6379/1
# Default per-IP: 10 req/min for admin routes, 5 req/min for settings PUT
# Failed-auth lockout: 20 attempts / 15 min sliding window per IP

# --- Anomaly Cooldown ---
# ANOMALY_INVESTIGATION_COOLDOWN_MINUTES=30  # min wait between AI investigations per asset

# --- Source API Keys (optional) ---
CHAINLINK_RPC_URL=
CHAINLINK_POR_CONTRACT=
ENABLE_CHAINLINK=false
ENABLE_DYNAMIC_CHAINS=false
# FRED API key — free tier from https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# RPC Polling — public Ankr endpoint (free, no key needed)
ANKR_PUBLIC_RPC=https://rpc.ankr.com/eth
RPC_POLL_INTERVAL_SECONDS=15
RPC_MAX_BLOCKS_PER_POLL=10
# FRED Polling (macro-economic yields)
FRED_POLL_INTERVAL_SECONDS=3600

# --- AI (optional add-on; core APIs work with AI_MODE=ai_off) ---
# AI_MODE values: ai_off (default), ai_lite (OpenRouter free + Ollama Cloud), ai_full (extended chain)
AI_MODE=ai_off
ENABLE_ANOMALY_DETECTION=false
ENABLE_NLP=false
# OpenRouter (primary provider for ai_lite + ai_full)
# Free tier: set OPENROUTER_API_KEY + OPENROUTER_FREE_MODEL=openrouter/free
# Paid tier: set OPENROUTER_MODEL=openai/gpt-4o-mini (default)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_FREE_MODEL=openrouter/free
# Ollama Cloud (fallback for ai_lite; secondary for ai_full)
# Get API key from https://ollama.com/settings/keys
OLLAMA_API_KEY=
OLLAMA_CLOUD_MODEL=ministral-3:8b-cloud
OLLAMA_CLOUD_FALLBACK_MODEL=qwen-2.5-7b-cloud
# Groq (fallback for ai_full mode)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# AI cache TTL in seconds (default 3600 = 1h)
AI_CACHE_TTL_SECONDS=3600
# Optional: inject web search results into AI prompts
AI_WEB_SEARCH=false
AI_WEB_SEARCH_MAX_RESULTS=3
# Token budget (daily, global)
AI_DAILY_TOKEN_BUDGET=50000
SENTIMENT_MAX_ARTICLES_PER_BATCH=15
MODEL_DIR=/data/models

# --- Alerts (optional) ---
ALERT_WEBHOOK_URL=
ALERT_DISCORD_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# --- Deploy (optional) ---
# HELIX_DEPLOY_REMOTE=user@host
# HELIX_SMOKE_URL=http://localhost:8000

# --- Security ---
# Content-Security-Policy header (backend + nginx). Customize for production:
# CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' https://cdn.jsdelivr.net 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# --- Admin ---
HELIX_ADMIN_TOKEN=
