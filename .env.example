# Copy to .env for local or Docker Compose: cp .env.example .env
#
# DATABASE_URL modes:
# - Local venv (from backend/): sqlite:///helix.db  -> backend/helix.db (default if unset)
# - Docker Compose: sqlite:///data/helix.db       -> /data/helix.db volume mount
# - Custom path: sqlite:////absolute/path/to/helix.db

# --- Core ---
HELIX_DOMAIN=helix.local
# Local dev (default):
DATABASE_URL=sqlite:///helix.db
# VPS / Timescale (docker compose --profile data):
# DATABASE_URL=postgresql+psycopg2://helix:helix@postgres:5432/helix
# HELIX_USE_ALEMBIC=true
# REDIS_URL=redis://redis:6379/0
# MLFLOW_TRACKING_URI=http://mlflow:5000
# SQLITE_SOURCE_URL=sqlite:///data/helix.db   # for scripts/migrate_sqlite_to_postgres.py
HELIX_USE_ALEMBIC=false
REDIS_URL=redis://localhost:6379/0
ENABLE_REDIS_CACHE=false
REDIS_CACHE_TTL_SECONDS=45
ENABLE_MLFLOW=true
ENABLE_PREDICTIVE=true
ONNX_DEPEG_MODEL_PATH=
REFRESH_INTERVAL_SECONDS=300
POSTGRES_USER=helix
POSTGRES_PASSWORD=helix
POSTGRES_DB=helix
TREND_RETENTION_DAYS=90
EVENT_RETENTION_DAYS=30
ALLOW_BACKFILL=false

# --- Source API Keys (optional) ---
DEFILLAMA_API_KEY=
COINGECKO_API_KEY=
ETHERSCAN_API_KEY=
CRYPTOPANIC_API_KEY=
ENABLE_CHAINLINK=false
ENABLE_DYNAMIC_CHAINS=false

# --- AI (optional add-on; core APIs work with AI_MODE=ai_off) ---
AI_MODE=ai_off
ENABLE_ANOMALY_DETECTION=false
ENABLE_NLP=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OLLAMA_CLOUD_BASE_URL=
OLLAMA_CLOUD_MODEL=llama3.2:3b
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_DAILY_TOKEN_BUDGET=50000

# --- Alerts (optional) ---
ALERT_WEBHOOK_URL=
ALERT_DISCORD_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_EMAIL_SMTP_HOST=

# --- Auth (optional) ---
ENABLE_AUTH=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=admin
PROMETHEUS_RETENTION_DAYS=30

# --- Production TLS (Docker Compose + Traefik) ---
# Set HELIX_DOMAIN to your public hostname before enabling Traefik TLS routes.
# Edit traefik/traefik.yml ACME email (admin@example.com placeholder).
# Create secrets/cloudflare_token.txt for Cloudflare DNS challenge (not committed).
# Touch acme.json locally with chmod 600 before first TLS issuance (gitignored).
# Replace default Traefik basic-auth (admin/changeme) in traefik/dynamic/middlewares.yml.
